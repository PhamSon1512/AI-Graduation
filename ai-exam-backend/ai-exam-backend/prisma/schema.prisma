generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enum definitions
enum UserRole {
  student
  teacher
  admin
}

enum BloomLevel {
  nhan_biet
  thong_hieu
  van_dung
  van_dung_cao
}

enum AiStatus {
  pending
  approved
  rejected
}

enum ExamStatus {
  draft
  pending
  approved
  rejected
}

enum QuestionType {
  trac_nghiem
  tu_luan
}

enum QuestionStatus {
  draft
  pending
  approved
}

enum OcrSessionStatus {
  processing
  pending_review
  saved
  cancelled
}

enum PracticeSessionStatus {
  in_progress
  completed
}

enum AssignmentType {
  fixed_exam
  random_config
}

enum AssignmentStatus {
  draft
  published
}

enum AssignmentAttemptStatus {
  in_progress
  completed
}

// Users table (Teachers & Students & Admin)
model User {
  id            Int       @id @default(autoincrement())
  fullName      String    @map("full_name") @db.VarChar(100)
  email         String    @unique @db.VarChar(100)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  role          UserRole
  className     String?   @map("class_name") @db.VarChar(50)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Password reset fields
  resetToken        String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpiry  DateTime? @map("reset_token_expiry")

  // Refresh token for JWT
  refreshToken      String?   @map("refresh_token") @db.Text

  // Relations
  createdExams            Exam[]              @relation("ExamCreator")
  approvedExams           Exam[]              @relation("ExamApprover")
  createdQuestions        Question[]          @relation("QuestionCreator")
  studentExamResults      StudentExamResult[] @relation("StudentResults")
  teacherSuggestions      AiSuggestion[]      @relation("TeacherSuggestions")
  studentSuggestions      AiSuggestion[]      @relation("StudentSuggestions")
  teacherSubjects         TeacherSubject[]    @relation("TeacherSubjects")
  studentSubjects         StudentSubject[]    @relation("StudentSubjects")
  ocrSessions             OcrSession[]        @relation("TeacherOcrSessions")
  teachingClasses         Class[]             @relation("TeacherClasses")
  enrolledClasses         ClassStudent[]      @relation("StudentClasses")
  practiceSessions       PracticeSession[]   @relation("StudentPractice")
  assignmentAttempts     AssignmentAttempt[] @relation("StudentAssignmentAttempts")
  createdAssignments    Assignment[]        @relation("TeacherAssignments")

  @@map("users")
}

// Questions bank table
model Question {
  id                Int             @id @default(autoincrement())
  examId            Int             @map("exam_id")
  orderNumber       Int             @default(0) @map("order_number")
  contentHtml       String          @map("content_html") @db.Text
  options           Json?           @map("options")
  questionType      QuestionType    @default(trac_nghiem) @map("question_type")
  topic             String          @db.VarChar(100)
  subjectId         Int             @map("subject_id")
  bloomLevel        BloomLevel      @map("bloom_level")
  correctAnswer     String?         @map("correct_answer") @db.VarChar(10)
  explanationHtml   String?         @map("explanation_html") @db.Text
  hasImage          Boolean         @default(false) @map("has_image")
  imageUrl          String?         @map("image_url") @db.VarChar(500)
  imageDescription  String?         @map("image_description") @db.Text
  isAiGenerated     Boolean         @default(false) @map("is_ai_generated")
  status            QuestionStatus  @default(draft)
  createdById       Int?            @map("created_by")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Relations
  exam                  Exam        @relation("ExamQuestions", fields: [examId], references: [id], onDelete: Cascade)
  subject               Subject     @relation("SubjectQuestions", fields: [subjectId], references: [id])
  createdBy             User?       @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  examQuestions         ExamQuestion[]
  studentQuestionLogs   StudentQuestionLog[]
  practiceSessionQuestions   PracticeSessionQuestion[]
  assignmentAttemptAnswers   AssignmentAttemptAnswer[]
  assignmentAttemptQuestions AssignmentAttemptQuestion[]

  @@map("questions")
}

// Exams table
model Exam {
  id              Int         @id @default(autoincrement())
  code            String      @unique @db.VarChar(50)
  title           String      @db.VarChar(200)
  description     String?     @db.Text
  subjectId       Int         @map("subject_id")
  totalQuestions  Int         @default(0) @map("total_questions")
  durationMinutes Int         @default(45) @map("duration_minutes")
  isAiGenerated   Boolean     @default(false) @map("is_ai_generated")
  status          ExamStatus  @default(draft)
  createdById     Int?        @map("created_by")
  approvedById    Int?        @map("approved_by")
  approvedAt      DateTime?   @map("approved_at")
  rejectionReason String?     @map("rejection_reason") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  subject             Subject             @relation(fields: [subjectId], references: [id])
  createdBy           User?               @relation("ExamCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy          User?               @relation("ExamApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  questions           Question[]          @relation("ExamQuestions")
  examQuestions       ExamQuestion[]
  studentExamResults   StudentExamResult[]
  ocrSessions         OcrSession[]
  assignments         Assignment[]
  assignmentAttempts  AssignmentAttempt[]

  @@map("exams")
}

// Exam-Question junction table
model ExamQuestion {
  examId      Int @map("exam_id")
  questionId  Int @map("question_id")

  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@map("exam_questions")
}

// Student exam results table
model StudentExamResult {
  id                Int       @id @default(autoincrement())
  studentId         Int       @map("student_id")
  examId            Int       @map("exam_id")
  totalScore        Decimal?  @map("total_score") @db.Decimal(4, 2)
  totalTimeSeconds  Int?      @map("total_time_seconds")
  submittedAt       DateTime  @default(now()) @map("submitted_at")

  // Relations
  student             User                  @relation("StudentResults", fields: [studentId], references: [id], onDelete: Cascade)
  exam                Exam                  @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentQuestionLogs StudentQuestionLog[]

  @@map("student_exam_results")
}

// Student question logs table (Important for AI analysis)
model StudentQuestionLog {
  id                Int     @id @default(autoincrement())
  resultId          Int     @map("result_id")
  questionId        Int     @map("question_id")
  studentAnswer     String? @map("student_answer") @db.Char(1)
  isCorrect         Boolean @map("is_correct")
  timeSpentSeconds  Int     @map("time_spent_seconds")

  // Relations
  result    StudentExamResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question  Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("student_question_logs")
}

// Subjects table (môn học)
model Subject {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  topics      Json?     @map("topics")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  teacherSubjects TeacherSubject[]
  studentSubjects StudentSubject[]
  exams           Exam[]
  questions       Question[]       @relation("SubjectQuestions")
  classes         Class[]          @relation("ClassSubject")
  topicList       Topic[]
  practiceSessions PracticeSession[]

  @@map("subjects")
}

// Topic table (chủ đề thuộc môn học)
model Topic {
  id          Int      @id @default(autoincrement())
  subjectId   Int      @map("subject_id")
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  practiceSessions PracticeSession[]

  @@unique([subjectId, code])
  @@map("topics")
}

// OCR Session table (phiên OCR tạm để teacher duyệt)
model OcrSession {
  id              Int               @id @default(autoincrement())
  examId          Int               @map("exam_id")
  teacherId       Int               @map("teacher_id")
  fileName        String?           @map("file_name") @db.VarChar(255)
  fileType        String?           @map("file_type") @db.VarChar(50)
  rawQuestions    Json              @map("raw_questions")
  reviewedData    Json?             @map("reviewed_data")
  status          OcrSessionStatus  @default(processing)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  exam    Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  teacher User  @relation("TeacherOcrSessions", fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("ocr_sessions")
}

// Teacher-Subject junction table (Giáo viên đăng ký môn dạy)
model TeacherSubject {
  id          Int       @id @default(autoincrement())
  teacherId   Int       @map("teacher_id")
  subjectId   Int       @map("subject_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")

  // Relations
  teacher User    @relation("TeacherSubjects", fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// Student-Subject junction table (Học sinh chọn môn học)
model StudentSubject {
  id          Int       @id @default(autoincrement())
  studentId   Int       @map("student_id")
  subjectId   Int       @map("subject_id")
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")

  // Relations
  student User    @relation("StudentSubjects", fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("student_subjects")
}

// AI suggestions table (Human in the loop feature)
model AiSuggestion {
  id                  Int       @id @default(autoincrement())
  teacherId           Int       @map("teacher_id")
  studentId           Int       @map("student_id")
  suggestedTopic      String?   @map("suggested_topic") @db.VarChar(100)
  generatedQuestions  Json?     @map("generated_questions")
  aiReasoning         String?   @map("ai_reasoning") @db.Text
  status              AiStatus  @default(pending)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  teacher User @relation("TeacherSuggestions", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentSuggestions", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("ai_suggestions")
}

// Class table (Lớp học)
model Class {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  code        String    @unique @db.VarChar(20)
  description String?   @db.Text
  schoolYear  String?   @map("school_year") @db.VarChar(20)
  teacherId   Int       @map("teacher_id")
  subjectId   Int?      @map("subject_id")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  teacher   User           @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject?       @relation("ClassSubject", fields: [subjectId], references: [id], onDelete: SetNull)
  students    ClassStudent[] @relation("ClassStudents")
  assignments Assignment[]

  @@map("classes")
}

// ClassStudent junction table (Học sinh trong lớp)
model ClassStudent {
  id          Int       @id @default(autoincrement())
  classId     Int       @map("class_id")
  studentId   Int       @map("student_id")
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  status      String    @default("active") @db.VarChar(20)

  // Relations
  class   Class @relation("ClassStudents", fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("StudentClasses", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_students")
}

// Practice Session (phiên luyện tập của học sinh)
model PracticeSession {
  id              Int                   @id @default(autoincrement())
  studentId       Int                   @map("student_id")
  subjectId       Int                   @map("subject_id")
  topicId         Int?                  @map("topic_id")
  status          PracticeSessionStatus @default(in_progress)
  totalQuestions  Int                   @map("total_questions")
  score           Decimal?              @db.Decimal(5, 2)
  createdAt       DateTime              @default(now()) @map("created_at")
  completedAt     DateTime?             @map("completed_at")

  // Relations
  student   User                      @relation("StudentPractice", fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic     Topic?                    @relation(fields: [topicId], references: [id], onDelete: SetNull)
  questions PracticeSessionQuestion[]

  @@map("practice_sessions")
}

// Practice Session Question (câu hỏi trong phiên luyện tập)
model PracticeSessionQuestion {
  id            Int     @id @default(autoincrement())
  sessionId     Int     @map("session_id")
  questionId    Int     @map("question_id")
  orderNumber   Int     @map("order_number")
  studentAnswer String? @map("student_answer") @db.VarChar(10)
  isCorrect     Boolean? @map("is_correct")

  // Relations
  session  PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("practice_session_questions")
}

// Assignment (bài tập giao cho lớp)
model Assignment {
  id              Int               @id @default(autoincrement())
  classId         Int               @map("class_id")
  teacherId       Int               @map("teacher_id")
  examId          Int?              @map("exam_id")
  title           String            @db.VarChar(200)
  description     String?           @db.Text
  assignmentType  AssignmentType    @map("assignment_type")
  examConfig      Json?             @map("exam_config")
  deadline        DateTime?         @db.Timestamptz(6)
  durationMinutes Int              @default(60) @map("duration_minutes")
  status          AssignmentStatus  @default(draft)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  class     Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User                @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  exam      Exam?               @relation(fields: [examId], references: [id], onDelete: SetNull)
  attempts  AssignmentAttempt[]

  @@map("assignments")
}

// AssignmentAttempt (mỗi học sinh làm 1 lần)
model AssignmentAttempt {
  id              Int                     @id @default(autoincrement())
  assignmentId     Int                     @map("assignment_id")
  studentId       Int                     @map("student_id")
  examId          Int?                    @map("exam_id")
  status          AssignmentAttemptStatus @default(in_progress)
  startedAt       DateTime                @default(now()) @map("started_at")
  submittedAt     DateTime?               @map("submitted_at")
  timeSpentSeconds Int?                  @map("time_spent_seconds")
  score           Decimal?                @db.Decimal(5, 2)
  createdAt       DateTime                @default(now()) @map("created_at")

  // Relations
  assignment   Assignment                 @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User                       @relation("StudentAssignmentAttempts", fields: [studentId], references: [id], onDelete: Cascade)
  exam         Exam?                      @relation(fields: [examId], references: [id], onDelete: SetNull)
  questions    AssignmentAttemptQuestion[]
  answers      AssignmentAttemptAnswer[]

  @@unique([assignmentId, studentId])
  @@map("assignment_attempts")
}

// AssignmentAttemptQuestion (câu hỏi trong attempt - dùng cho random type)
model AssignmentAttemptQuestion {
  id            Int     @id @default(autoincrement())
  attemptId     Int     @map("attempt_id")
  questionId    Int     @map("question_id")
  orderNumber   Int     @map("order_number")

  // Relations
  attempt  AssignmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("assignment_attempt_questions")
}

// AssignmentAttemptAnswer (đáp án học sinh chọn)
model AssignmentAttemptAnswer {
  id            Int     @id @default(autoincrement())
  attemptId     Int     @map("attempt_id")
  questionId    Int     @map("question_id")
  studentAnswer String? @map("student_answer") @db.VarChar(10)
  isCorrect     Boolean? @map("is_correct")

  // Relations
  attempt  AssignmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("assignment_attempt_answers")
}